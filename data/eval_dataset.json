{
  "name": "sample-mcp-tests",
  "description": "Sample eval dataset for MCP server testing",
  "cases": [
    {
      "id": "get-weather-london",
      "description": "Get weather for London",
      "toolName": "get_weather",
      "args": {
        "city": "London"
      },
      "expect": {
        "schema": "weather-response"
      }
    },
    {
      "id": "get-weather-tokyo",
      "description": "Get weather for Tokyo",
      "toolName": "get_weather",
      "args": {
        "city": "Tokyo"
      },
      "expect": {
        "schema": "weather-response"
      }
    },
    {
      "id": "search-docs-mcp",
      "description": "Search documentation for MCP information",
      "toolName": "search_docs",
      "args": {
        "query": "Model Context Protocol",
        "limit": 5
      },
      "expect": {
        "passesJudge": {
          "rubric": "Search results should be relevant to MCP",
          "configId": "search-relevance"
        }
      }
    },
    {
      "id": "calculate-sum",
      "description": "Calculate sum of two numbers",
      "toolName": "calculate",
      "args": {
        "operation": "add",
        "a": 10,
        "b": 20
      },
      "expect": {
        "containsText": "30"
      }
    },
    {
      "id": "city-info-markdown-contains",
      "description": "Validate city info markdown contains expected sections",
      "toolName": "get_city_info",
      "args": {
        "city": "London"
      },
      "expect": {
        "containsText": [
          "## City Information",
          "**City:** London",
          "### Features",
          "- Public Transportation"
        ]
      }
    },
    {
      "id": "city-info-markdown-regex",
      "description": "Validate city info markdown format with regex patterns",
      "toolName": "get_city_info",
      "args": {
        "city": "London"
      },
      "expect": {
        "matchesPattern": [
          "^## City Information",
          "\\*\\*City:\\*\\* \\w+",
          "\\*\\*Population:\\*\\* [\\d.]+M",
          "^### Features",
          "^- [\\w\\s]+",
          "Temperature: \\d+°C",
          "\\d{4}-\\d{2}-\\d{2}"
        ]
      }
    }
  ],
  "metadata": {
    "version": "1.0",
    "author": "@gleanwork/mcp-server-tester",
    "created": "2025-01-22"
  }
}
